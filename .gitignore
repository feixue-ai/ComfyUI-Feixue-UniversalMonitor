# ============================================
# ComfyUI-Feixue-UniversalMonitor .gitignore
# ============================================

# 临时文件目录（开发过程中的废弃/备份文件）
TEMPV1/

# Python 编译缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
ENV/
env/
.venv/

# IDE / 编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# OS 文件
.DS_Store
Thumbs.db

# 敏感信息（绝不能上传！）
*.pem
*.key
*密钥*
*PAT*
*pat*
*token*
*secret*

# 日志
*.log

# 编译产物（bridge DLL 已预编译在 libs/，build/ 仅为本地编译缓存）
build/
