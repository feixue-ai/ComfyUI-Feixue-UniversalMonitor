# ============================================================================
# ComfyUI-Feixue-UniversalMonitor - EditorConfig
# ============================================================================
# 编辑器统一配置
#
# 功能:
#   - 统一不同编辑器（VS Code, PyCharm, Vim, Emacs 等）的代码格式
#   - 确保缩进、字符集、换行符等设置一致
#   - 避免因编辑器差异导致的格式问题
#
# 支持的编辑器:
#   - VS Code (需要安装 EditorConfig 扩展)
#   - PyCharm / IntelliJ (内置支持)
#   - Vim / Neovim (需要安装 editorconfig-vim 插件)
#   - Emacs (需要安装 editorconfig-emacs 插件)
#   - Sublime Text (需要安装 EditorConfig 插件)
#   - Atom (内置支持)
#
# 安装:
#   VS Code: 搜索 "EditorConfig for VS Code" 并安装
#   Vim: Plugin 'editorconfig/editorconfig-vim'
#
# 文档: https://editorconfig.org/
# ============================================================================

# 根配置文件标记（必须放在第一行）
root = true

# ============================================================================
# 全局默认设置（适用于所有文件）
# ============================================================================
[*]
# 字符编码：UTF-8（现代标准）
charset = utf-8

# 换行符：LF（Unix/Linux/macOS 标准，避免 CRLF 问题）
end_of_line = lf

# 文件末尾插入空行（符合 POSIX 标准）
insert_final_newline = true

# 删除行尾空白字符（避免 git diff 噪音）
trim_trailing_whitespace = true

# 缩进风格：空格（Python 官方推荐）
indent_style = space

# 缩进大小：4 空格（PEP 8 推荐）
indent_size = 4

# ============================================================================
# Python 文件特定配置
# ============================================================================
[*.py]
# Python 使用 4 空格缩进（PEP 8 标准）
indent_size = 4

# 最大行长度：120 字符（比 PEP 8 的 79 更现代）
max_line_length = 120

# 不修剪 Markdown 字符串中的尾部空格（保持文档格式）
# trim_trailing_whitespace = false  # 如果有 docstring 包含格式化内容

# ============================================================================
# JavaScript/TypeScript/CSS/HTML 文件配置
# ============================================================================
[*.{js,jsx,ts,tsx,css,scss,html,vue,svelte}]
# Web 开发通常使用 2 空格缩进
indent_size = 2

# 最大行长度：100 字符（Web 标准惯例）
max_line_length = 100

# ============================================================================
# JSON 文件配置
# ============================================================================
[*.json]
# JSON 通常使用 2 空格缩进
indent_size = 2

# 不修剪尾部空格（某些 JSON 格式化工具会添加）
trim_trailing_whitespace = false

# ============================================================================
# YAML 文件配置
# ============================================================================
[*.{yml,yaml}]
# YAML 使用 2 空格缩进（官方推荐）
indent_size = 2

# ============================================================================
# Markdown 文件配置
# ============================================================================
[*.md]
# Markdown 中不修剪尾部空格（保留换行和列表格式）
trim_trailing_whitespace = false

# 最大行长度：不限制（Markdown 需要灵活换行）
max_line_length = off

# ============================================================================
# 配置文件（INI、TOML、CFG 等）
# ============================================================================
[*.{ini,toml,cfg,conf}]
# 配置文件通常使用 4 或 2 空格
indent_size = 4

# ============================================================================
# Shell/Bash 脚本
# ============================================================================
[*.sh]
# Shell 脚本使用 4 空格或 2 tab
indent_size = 4

# ============================================================================
# Makefile（必须使用 Tab！）
# ============================================================================
[Makefile]
# Makefile 必须使用 Tab 缩进（这是 Make 的语法要求）
indent_style = tab

# ============================================================================
# Dockerfile
# ============================================================================
[Dockerfile*]
# Dockerfile 通常使用 4 空格
indent_size = 4

# ============================================================================
# bat/cmd 脚本（Windows）
# ============================================================================
[*.bat]
# Windows 脚本
indent_size = 4
end_of_line = crlf  # Windows 使用 CRLF

# ============================================================================
# 特定文件忽略规则
# ============================================================================

# vendor 目录下的文件（第三方代码，不修改）
[**/vendor/**]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = unset
insert_final_newline = unset

# 生成的文件（自动生成，不需要手动编辑）
[**/{generated,auto}/**]
trim_trailing_whitespace = unset

# 数据文件（二进制或特殊格式）
[*.{csv,tsv,log}]
insert_final_newline = unset
trim_trailing_whitespace = unset

# 压缩文件和二进制文件
[*.{png,jpg,gif,ico,bmp,svg,webp,eot,ttf,woff,woff2}]
insert_final_newline = unset
trim_trailing_whitespace = unset

# 锁定文件（pip poetry 等）
[*{.lock,poetry.lock,Pipfile.lock}]
indent_size = unset

# ============================================================================
# VS Code 特定设置（可选）
# ============================================================================
# 可以在 .vscode/settings.json 中覆盖：
# {
#   "editor.tabSize": 4,
#   "editor.insertSpaces": true,
#   "files.eol": "\n",
#   "files.trimTrailingWhitespace": true,
#   "files.insertFinalNewline": true,
#   "python.formatting.provider": "black",
#   "[python]": {
#     "editor.tabSize": 4,
#     "editor.rulers": [120],
#     "editor.wordWrapColumn": 120
#   }
# }
